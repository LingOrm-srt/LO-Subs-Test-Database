    "ONLY_YOU_EP_01": {
      "en": [{"start": 0.1, "end": 5, "text": "✨ LingOrm Subs Connected", "type": "note"},{"start":72.72,"end":75.12,"text":"(8 years ago)","type":"dialogue"},{"start":75.12,"end":76.52,"text":"Hey, baby girl!","type":"dialogue"},{"start":76.52,"end":79.44,"text":"Help! Help!","type":"dialogue"},{"start":79.44,"end":80.68,"text":"Hey, hey, hey.","type":"dialogue"},{"start":81.24,"end":83,"text":"-Where are you going? <br> -Where are you going?","type":"dialogue"},{"start":83.12,"end":84.48,"text":"Help!","type":"dialogue"},{"start":87.16,"end":89.56,"text":"-Don't hurt me. Don't hurt me. -Come with me.","type":"dialogue"},{"start":90.68,"end":93.52,"text":"I'm begging you. Please let me go.","type":"dialogue"},{"start":120.2,"end":121.32,"text":"Hey!","type":"dialogue"},{"start":145.44,"end":146.44,"text":"Hey!","type":"dialogue"},{"start":165.44,"end":167.36,"text":"Don't harass women again!","type":"dialogue"},{"start":168.8,"end":171.2,"text":"-Go! -Let's go.","type":"dialogue"},{"start":171.56,"end":172.44,"text":"Come on.","type":"dialogue"},{"start":172.92,"end":173.92,"text":"Let's go.","type":"dialogue"},{"start":174.44,"end":175.6,"text":"Let's go.","type":"dialogue"},{"start":225.32,"end":226.6,"text":"Can you stand?","type":"dialogue"},{"start":232.92,"end":234.4,"text":"Are you hurt anywhere?","type":"dialogue"},{"start":237.6,"end":239.2,"text":"How will you get home?","type":"dialogue"},{"start":244.92,"end":246.76,"text":"My driver should be around here.","type":"dialogue"},{"start":247.36,"end":250.24,"text":"But my phone's dead.","type":"dialogue"},{"start":255.04,"end":256.04,"text":"Come on.","type":"dialogue"},{"start":264.88,"end":266.56,"text":"I'll help you find your car.","type":"dialogue"},{"start":295.36,"end":296.36,"text":"Cover yourself.","type":"dialogue"},{"start":298.56,"end":299.8,"text":"Your shirt is thin.","type":"dialogue"},{"start":338.4,"end":340.56,"text":"Oh! That's my car.","type":"dialogue"},{"start":346.88,"end":349.24,"text":"Thank you very much for saving me today.","type":"dialogue"},{"start":351.08,"end":353.44,"text":"My name's Ayla. What's yours?","type":"dialogue"},{"start":362.52,"end":363.16,"text":"Thank you.","type":"dialogue"},{"start":416.36,"end":417.56,"text":"Miss Jacket.","type":"dialogue"},{"start":420.8,"end":423.8,"text":"How is your owner so freaking cool?","type":"dialogue"},{"start":424.48,"end":426.4,"text":"She fought off three men.","type":"dialogue"},{"start":426.64,"end":429,"text":"With an umbrella like this.","type":"dialogue"},{"start":430.16,"end":433,"text":"How is she pretty, talented and cool?","type":"dialogue"},{"start":434.6,"end":436,"text":"Only one drawback.","type":"dialogue"},{"start":438.16,"end":439.88,"text":"She wouldn't tell me her name.","type":"dialogue"},{"start":452.28,"end":454.92,"text":"So how am I going to return this?","type":"dialogue"},{"start":458.44,"end":460.28,"text":"I'll probably never see her again.","type":"dialogue"},{"start":461.2,"end":462.72,"text":"So you'd better stay with me.","type":"dialogue"},{"start":468.28,"end":469.64,"text":"I'm talking to a jacket.","type":"dialogue"},{"start":482.76,"end":485.04,"text":"Hi, new kid. What's your name?","type":"dialogue"},{"start":485.96,"end":487.36,"text":"I'm Ayla.","type":"dialogue"},{"start":487.44,"end":488.92,"text":"And your first name?","type":"dialogue"},{"start":489.68,"end":490.88,"text":"Sasina.","type":"dialogue"},{"start":491.8,"end":493.04,"text":"And your last name?","type":"dialogue"},{"start":496,"end":497.48,"text":"Ruengkunakorn.","type":"dialogue"},{"start":498.72,"end":501.92,"text":"Hi, new friend. I'm Khaotu, Suthasinee Sawangkamol.","type":"dialogue"},{"start":502.24,"end":503.8,"text":"I've been here since Grade 7.","type":"dialogue"},{"start":504.88,"end":507.12,"text":"Nice to meet you, Ayla Sasina.","type":"dialogue"},{"start":507.76,"end":510.84,"text":"-Nice to meet... -If you have questions, feel free to ask me","type":"dialogue"},{"start":510.92,"end":513.4,"text":"because I know everything","type":"dialogue"},{"start":513.4,"end":515.919,"text":"and everyone in this school.","type":"dialogue"},{"start":516,"end":517.4,"text":"But if grades stress you out,","type":"dialogue"},{"start":517.48,"end":519.6,"text":"you have nothing to worry about","type":"dialogue"},{"start":519.6,"end":521.12,"text":"because I...","type":"dialogue"},{"start":522.159,"end":524.32,"text":"get an A in every subject.","type":"dialogue"},{"start":525.84,"end":527.52,"text":"Okay, you're good.","type":"dialogue"},{"start":527.6,"end":530.52,"text":"Wanna hang out in the classroom or...","type":"dialogue"},{"start":532.52,"end":533.52,"text":"Hey!","type":"dialogue"},{"start":533.76,"end":534.76,"text":"Hey.","type":"dialogue"},{"start":535.44,"end":536.52,"text":"Khaotu.","type":"dialogue"},{"start":536.52,"end":539.04,"text":"(Don't leave this door open. Always close the door.)","type":"dialogue"},{"start":539.04,"end":540.04,"text":"Come on.","type":"dialogue"},{"start":543.2,"end":544.2,"text":"Come on.","type":"dialogue"},{"start":546.48,"end":548.64,"text":"-So glad we got here in time. -What's that?","type":"dialogue"},{"start":549.36,"end":550.32,"text":"Begin!","type":"dialogue"},{"start":550.4,"end":551.92,"text":"It's called kendo.","type":"dialogue"},{"start":552.24,"end":555,"text":"It's easy to follow. You score for every good hit.","type":"dialogue"},{"start":559.4,"end":560.8,"text":"You're awesome!","type":"dialogue"},{"start":561.64,"end":563,"text":"Wow!","type":"dialogue"},{"start":563.88,"end":566.36,"text":"-Wow! -She's so good.","type":"dialogue"},{"start":566.36,"end":567.48,"text":"Resume play!","type":"dialogue"},{"start":600.16,"end":601,"text":"We've got a winner!","type":"dialogue"},{"start":640.04,"end":641.08,"text":"Hey, don't block.","type":"dialogue"},{"start":641.08,"end":642.8,"text":"-Sit down, sit down. -Hey.","type":"dialogue"},{"start":645.72,"end":646.84,"text":"That senior.","type":"dialogue"},{"start":647.32,"end":648.44,"text":"She...","type":"dialogue"},{"start":651.4,"end":652.76,"text":"Her name is Tawan.","type":"dialogue"},{"start":652.84,"end":656.04,"text":"She's in Grade 12. An outstanding student.","type":"dialogue"},{"start":656.04,"end":657.48,"text":"The school president.","type":"dialogue"},{"start":657.56,"end":660.36,"text":"And she's our school's kendo champion.","type":"dialogue"},{"start":660.92,"end":663.32,"text":"She's a three-time champion.","type":"dialogue"},{"start":664.12,"end":665.2,"text":"Wow.","type":"dialogue"},{"start":665.8,"end":667.4,"text":"Good at school and sports?","type":"dialogue"},{"start":668.48,"end":670.56,"text":"She's good at everything.","type":"dialogue"},{"start":672.04,"end":673.4,"text":"And she's pretty.","type":"dialogue"},{"start":673.48,"end":675.72,"text":"Cool. The word is \"cool.","type":"dialogue"},{"start":677.12,"end":679.48,"text":"Anyway, what club are you joining?","type":"dialogue"},{"start":684,"end":685.4,"text":"(Come Join the Kendo Club)","type":"dialogue"},{"start":688.84,"end":691.12,"text":"Are you really sure?","type":"dialogue"},{"start":691.12,"end":692.16,"text":"I am.","type":"dialogue"},{"start":692.16,"end":694,"text":"I want to join the kendo club.","type":"dialogue"},{"start":697.36,"end":698.36,"text":"But...","type":"dialogue"},{"start":698.56,"end":701.36,"text":"I think the training is very intense.","type":"dialogue"},{"start":701.56,"end":703.44,"text":"I don't think you can handle it.","type":"dialogue"},{"start":705.36,"end":706.88,"text":"I'm sure I can handle it.","type":"dialogue"},{"start":707.68,"end":709.36,"text":"I'm super ready. I'm all in.","type":"dialogue"},{"start":711.92,"end":714.92,"text":"Let's see how you do in a tryout.","type":"dialogue"},{"start":715,"end":716.48,"text":"Are you guys ready?","type":"dialogue"},{"start":717.92,"end":719,"text":"Yes!","type":"dialogue"},{"start":741.76,"end":745.04,"text":"By the look of it, that wimp won't make it.","type":"dialogue"},{"start":745.84,"end":748.28,"text":"Look at her. She's about to faint.","type":"dialogue"},{"start":750.16,"end":751.96,"text":"Let her join if she wanna join.","type":"dialogue"},{"start":753.28,"end":754.16,"text":"True.","type":"dialogue"},{"start":755.04,"end":756.84,"text":"And who's gonna train her?","type":"dialogue"},{"start":760.48,"end":761.4,"text":"I will.","type":"dialogue"},{"start":763.52,"end":764.76,"text":"You said it.","type":"dialogue"},{"start":765.32,"end":766.8,"text":"You train her.","type":"dialogue"},{"start":767.08,"end":768.08,"text":"Deal?","type":"dialogue"},{"start":768.88,"end":769.88,"text":"Deal.","type":"dialogue"},{"start":772.36,"end":773.48,"text":"All right.","type":"dialogue"},{"start":773.76,"end":775.36,"text":"Kid, no more running.","type":"dialogue"},{"start":775.44,"end":776.76,"text":"You're in.","type":"dialogue"},{"start":776.76,"end":777.92,"text":"Very good effort.","type":"dialogue"},{"start":778.36,"end":780,"text":"See you tomorrow at the club.","type":"dialogue"},{"start":791.48,"end":793.12,"text":"Get up and drink some water.","type":"dialogue"},{"start":798.96,"end":800.4,"text":"Hey, Tawan.","type":"dialogue"},{"start":804.6,"end":805.76,"text":"I feel lightheaded.","type":"dialogue"},{"start":807.48,"end":808.52,"text":"Are you okay?","type":"dialogue"},{"start":817.48,"end":818.92,"text":"Thank you, Tawan.","type":"dialogue"},{"start":822.76,"end":824.28,"text":"Do you remember me?","type":"dialogue"},{"start":831.32,"end":832.76,"text":"You know my name now.","type":"dialogue"},{"start":833.04,"end":834.52,"text":"This club is demanding.","type":"dialogue"},{"start":835.96,"end":836.96,"text":"Yes.","type":"dialogue"},{"start":838.2,"end":840.32,"text":"I'll try my best.","type":"dialogue"},{"start":841.08,"end":842.92,"text":"Thank you for accepting me.","type":"dialogue"},{"start":844.52,"end":845.52,"text":"Go.","type":"dialogue"},{"start":846.52,"end":847.56,"text":"Time to go home.","type":"dialogue"},{"start":849,"end":850.64,"text":"See you at the club tomorrow.","type":"dialogue"},{"start":852,"end":853.08,"text":"Ayla.","type":"dialogue"},{"start":856.2,"end":857.6,"text":"Bye-bye, Tawan!","type":"dialogue"},{"start":862.92,"end":865.08,"text":"She knows my name.","type":"dialogue"},{"start":868.68,"end":870.32,"text":"She knows my name.","type":"dialogue"},{"start":876.64,"end":877.64,"text":"Ah!","type":"dialogue"},{"start":896.64,"end":898.36,"text":"Before we start,","type":"dialogue"},{"start":899,"end":901.4,"text":"I'll show you how we train kendo.","type":"dialogue"},{"start":903.8,"end":905.72,"text":"Fight! Begin!","type":"dialogue"},{"start":921.96,"end":923.96,"text":"Head! Begin!","type":"dialogue"},{"start":931.68,"end":933.28,"text":"Wrist! Begin!","type":"dialogue"},{"start":939.56,"end":941.44,"text":"Torso! Begin!","type":"dialogue"},{"start":946.36,"end":947.84,"text":"Bow!","type":"dialogue"},{"start":950.12,"end":953.24,"text":"You will start from the fundamentals.","type":"dialogue"},{"start":953.56,"end":954.72,"text":"Are you ready?","type":"dialogue"},{"start":954.8,"end":955.88,"text":"-Yes! -Yes!","type":"dialogue"},{"start":960.64,"end":961.8,"text":"Kendo,","type":"dialogue"},{"start":962.16,"end":963.72,"text":"the way of the sword,","type":"dialogue"},{"start":964.48,"end":967.32,"text":"is based on the samurai swordsmanship.","type":"dialogue"},{"start":967.84,"end":970.28,"text":"To train the kendo fighting moves","type":"dialogue"},{"start":970.96,"end":974.52,"text":"that are fast, forceful and decisive,","type":"dialogue"},{"start":974.84,"end":977.92,"text":"deep concentration is required.","type":"dialogue"},{"start":992.12,"end":993.12,"text":"Come on.","type":"dialogue"},{"start":999.84,"end":1002.04,"text":"Come on! Run!","type":"dialogue"},{"start":1028,"end":1028.92,"text":"Whoa!","type":"dialogue"},{"start":1029,"end":1030.28,"text":"Give us some.","type":"dialogue"},{"start":1031.4,"end":1032.72,"text":"Yeah, take some.","type":"dialogue"},{"start":1033.52,"end":1035.24,"text":"-Give me some. -This one too.","type":"dialogue"},{"start":1100.16,"end":1102.44,"text":"Tawan got my gift.","type":"dialogue"},{"start":1105.8,"end":1107.2,"text":"She got my gift.","type":"dialogue"},{"start":1128.16,"end":1129.76,"text":"It's really pouring.","type":"dialogue"},{"start":1132.4,"end":1133.4,"text":"Tawan.","type":"dialogue"},{"start":1134.36,"end":1135.52,"text":"You haven't left?","type":"dialogue"},{"start":1136.68,"end":1139.68,"text":"Well, I forgot to bring my umbrella.","type":"dialogue"},{"start":1145,"end":1146.84,"text":"I forgot my umbrella too.","type":"dialogue"},{"start":1148,"end":1149,"text":"So...","type":"dialogue"},{"start":1149.8,"end":1151.68,"text":"why don't we find rain stoppers?","type":"dialogue"},{"start":1153.84,"end":1154.96,"text":"Rain stoppers?","type":"dialogue"},{"start":1156.04,"end":1157.08,"text":"What's that?","type":"dialogue"},{"start":1157.88,"end":1159.24,"text":"Let's make rain chasers.","type":"dialogue"},{"start":1160.04,"end":1161.28,"text":"Rain chasers?","type":"dialogue"},{"start":1180.48,"end":1181.52,"text":"Here.","type":"dialogue"},{"start":1194.56,"end":1197.8,"text":"Ooh, there's the sun. Very cool.","type":"dialogue"},{"start":1199,"end":1201.76,"text":"The sun is another word for \"tawan.","type":"dialogue"},{"start":1210.32,"end":1212.04,"text":"Are you drawing the moon?","type":"dialogue"},{"start":1213.36,"end":1214.48,"text":"That's right.","type":"dialogue"},{"start":1215.48,"end":1217.2,"text":"Why the moon?","type":"dialogue"},{"start":1218.92,"end":1220.92,"text":"Ayla is another word for the moon.","type":"dialogue"},{"start":1222.84,"end":1223.84,"text":"I see.","type":"dialogue"},{"start":1231.16,"end":1233.12,"text":"The sun and the moon.","type":"dialogue"},{"start":1233.84,"end":1235.24,"text":"Tawan and Ayla.","type":"dialogue"},{"start":1235.24,"end":1239.2,"text":"♪ Never once did you notice ♪","type":"dialogue"},{"start":1239.2,"end":1242.72,"text":"♪ What my heart was feeling ♪","type":"dialogue"},{"start":1242.72,"end":1246.24,"text":"♪ When I look at you, my eyes say it all ♪","type":"dialogue"},{"start":1246.32,"end":1251.16,"text":"♪ Waiting only for you to pay me attention ♪","type":"dialogue"},{"start":1251.24,"end":1257.56,"text":"♪ My heart yells every day But its voice never reaches you ♪","type":"dialogue"},{"start":1257.56,"end":1261.6,"text":"♪ I want you to know how long I've kept this in ♪","type":"dialogue"},{"start":1261.6,"end":1266.24,"text":"♪ Do you have any idea ♪","type":"dialogue"},{"start":1266.24,"end":1268.92,"text":"♪ As each minute goes by ♪","type":"dialogue"},{"start":1268.92,"end":1274.64,"text":"♪ How much my heart wants to say I love you? ♪","type":"dialogue"},{"start":1275.68,"end":1279.56,"text":"♪ All I know is my heart's stubborn ♪","type":"dialogue"},{"start":1279.56,"end":1281.92,"text":"♪ Even when you ignore me ♪","type":"dialogue"},{"start":1281.92,"end":1283.6,"text":"- ♪ There's pain but also love ♪ - Here we go.","type":"dialogue"},{"start":1283.6,"end":1287.76,"text":"♪ That has never lessened ♪","type":"dialogue"},{"start":1287.76,"end":1291.76,"text":"♪ The closer we are, the further it feels ♪","type":"dialogue"},{"start":1291.76,"end":1295.2,"text":"♪ Never once ♪","type":"dialogue"},{"start":1295.2,"end":1299.12,"text":"♪ Did you notice what ♪","type":"dialogue"},{"start":1299.12,"end":1302.36,"text":"♪ My heart was feeling ♪","type":"dialogue"},{"start":1302.8,"end":1304.64,"text":"♪ When I look at you ♪","type":"dialogue"},{"start":1304.64,"end":1307,"text":"- ♪ My eyes say it all ♪ - Look! The rain stops.","type":"dialogue"},{"start":1307,"end":1311.68,"text":"- ♪ Waiting only for you to pay me attention ♪ - It really works.","type":"dialogue"},{"start":1311.68,"end":1317,"text":"♪ My heart yells every day But its voice never reaches you ♪","type":"dialogue"},{"start":1317,"end":1319.64,"text":"- ♪ I want you to know ♪ - Thank you, rain chasers.","type":"dialogue"},{"start":1319.64,"end":1322.08,"text":"♪ How long I've kept this in ♪","type":"dialogue"},{"start":1322.08,"end":1326.68,"text":"♪ Do you have any idea ♪","type":"dialogue"},{"start":1326.68,"end":1329.36,"text":"♪ As each minute goes by ♪","type":"dialogue"},{"start":1329.36,"end":1334.88,"text":"♪ How much my heart wants to say I love you? ♪","type":"dialogue"},{"start":1338.52,"end":1339.56,"text":"Tawan.","type":"dialogue"},{"start":1343.12,"end":1345.12,"text":"I'm good. Thank you.","type":"dialogue"},{"start":1346.68,"end":1348.24,"text":"-I'll take that. -Tawan.","type":"dialogue"},{"start":1367.04,"end":1368.04,"text":"Hey.","type":"dialogue"}],
      "es": [{"start":0.1,"end":5,"text":"✨ LingOrm Subs Connected","type":"note"},{"start":72.72,"end":75.12,"text":"(Hace 8 años)","type":"dialogue"},{"start":75.12,"end":76.52,"text":"¡Oye, preciosa!","type":"dialogue"},{"start":76.52,"end":79.44,"text":"¡Auxilio! ¡Ayuda!","type":"dialogue"},{"start":79.44,"end":80.68,"text":"Oye, oye, oye","type":"dialogue"},{"start":81.24,"end":83,"text":"-¿A dónde vas?\\n-¿A dónde vas?","type":"dialogue"},{"start":83.12,"end":84.48,"text":"¡Ayuda!","type":"dialogue"},{"start":87.16,"end":89.56,"text":"-No me hagas daño. No me hagas daño.\\n-Ven conmigo","type":"dialogue"},{"start":90.68,"end":93.52,"text":"Te lo ruego. Por favor, déjame ir","type":"dialogue"},{"start":120.2,"end":121.32,"text":"¡Oye!","type":"dialogue"},{"start":145.44,"end":146.44,"text":"¡Oye!","type":"dialogue"},{"start":165.44,"end":167.36,"text":"¡No vuelvan a molestar a una mujer!","type":"dialogue"},{"start":168.8,"end":171.2,"text":"-¡Fuera!\\n-Vámonos","type":"dialogue"},{"start":171.56,"end":172.44,"text":"Vamos","type":"dialogue"},{"start":172.92,"end":173.92,"text":"Vámonos","type":"dialogue"},{"start":174.44,"end":175.6,"text":"Vámonos","type":"dialogue"},{"start":225.32,"end":226.6,"text":"¿Puedes levantarte?","type":"dialogue"},{"start":232.92,"end":234.4,"text":"¿Te duele algo?","type":"dialogue"},{"start":237.6,"end":239.2,"text":"¿Cómo volverás a casa?","type":"dialogue"},{"start":244.92,"end":246.76,"text":"Mi chofer debe estar por aquí","type":"dialogue"},{"start":247.36,"end":250.24,"text":"Pero mi teléfono se quedó sin batería","type":"dialogue"},{"start":255.04,"end":256.04,"text":"Ven","type":"dialogue"},{"start":264.88,"end":266.56,"text":"Te ayudaré a buscar tu auto","type":"dialogue"},{"start":295.36,"end":296.36,"text":"Cúbrete","type":"dialogue"},{"start":298.56,"end":299.8,"text":"Tu camisa es delgada","type":"dialogue"},{"start":338.4,"end":340.56,"text":"¡Ah! Ese es mi auto","type":"dialogue"},{"start":346.88,"end":349.24,"text":"Muchas gracias por salvarme hoy","type":"dialogue"},{"start":351.08,"end":353.44,"text":"Mi nombre es Ayla. ¿Cuál es el tuyo?","type":"dialogue"},{"start":362.52,"end":363.16,"text":"Gracias","type":"dialogue"},{"start":416.36,"end":417.56,"text":"Señorita Chaqueta","type":"dialogue"},{"start":420.8,"end":423.8,"text":"¿Cómo puede tu dueña ser tan malditamente genial?","type":"dialogue"},{"start":424.48,"end":426.4,"text":"Se enfrentó a tres hombres","type":"dialogue"},{"start":426.64,"end":429,"text":"Solo con un paraguas como este","type":"dialogue"},{"start":430.16,"end":433,"text":"¿Cómo puede ser tan linda, talentosa y genial?","type":"dialogue"},{"start":840.32,"end":436,"text":"Solo tiene un defecto","type":"dialogue"},{"start":840.32,"end":439.88,"text":"No quiso decirme su nombre","type":"dialogue"},{"start":452.28,"end":454.92,"text":"Entonces, ¿cómo voy a devolver esto?","type":"dialogue"},{"start":458.44,"end":460.28,"text":"Probablemente no vuelva a verla nunca más","type":"dialogue"},{"start":461.2,"end":462.72,"text":"Así que mejor quédate conmigo","type":"dialogue"},{"start":468.28,"end":469.64,"text":"Le estoy hablando a una chaqueta","type":"dialogue"},{"start":482.76,"end":485.04,"text":"Hola, nueva. ¿Cómo te llamas?","type":"dialogue"},{"start":485.96,"end":487.36,"text":"Soy Ayla","type":"dialogue"},{"start":487.44,"end":488.92,"text":"¿Y tu nombre de pila?","type":"dialogue"},{"start":489.68,"end":490.88,"text":"Sasina","type":"dialogue"},{"start":491.8,"end":493.04,"text":"¿Y tu apellido?","type":"dialogue"},{"start":840.32,"end":497.48,"text":"Ruengkunakorn","type":"dialogue"},{"start":840.32,"end":501.92,"text":"Hola, nueva amiga. Soy Khaotu, Suthasinee Sawangkamol","type":"dialogue"},{"start":502.24,"end":503.8,"text":"He estado aquí desde séptimo grado","type":"dialogue"},{"start":504.88,"end":507.12,"text":"Mucho gusto, Ayla Sasina","type":"dialogue"},{"start":507.76,"end":510.84,"text":"-Mucho gus...\\n-Si tienes dudas, no dudes en preguntarme,","type":"dialogue"},{"start":510.92,"end":513.4,"text":"porque lo sé todo","type":"dialogue"},{"start":513.4,"end":515.919,"text":"y conozco a todos en esta escuela","type":"dialogue"},{"start":516,"end":517.4,"text":"Pero si las notas te estresan,","type":"dialogue"},{"start":517.48,"end":519.6,"text":"no tienes de qué preocuparte","type":"dialogue"},{"start":519.6,"end":521.12,"text":"porque yo...","type":"dialogue"},{"start":522.159,"end":524.32,"text":"saco A en cada materia","type":"dialogue"},{"start":525.84,"end":527.52,"text":"Vale, eres buena","type":"dialogue"},{"start":527.6,"end":530.52,"text":"¿Quieres pasar el rato en el salón o...?","type":"dialogue"},{"start":532.52,"end":533.52,"text":"¡Oye!","type":"dialogue"},{"start":533.76,"end":534.76,"text":"Hola","type":"dialogue"},{"start":535.44,"end":536.52,"text":"Khaotu","type":"dialogue"},{"start":536.52,"end":539.04,"text":"(No dejen esta puerta abierta. Ciérrenla siempre.)","type":"dialogue"},{"start":539.04,"end":540.04,"text":"Vamos","type":"dialogue"},{"start":543.2,"end":544.2,"text":"Vamos","type":"dialogue"},{"start":546.48,"end":548.64,"text":"-Qué bueno que llegamos a tiempo.\\n-¿Qué es eso?","type":"dialogue"},{"start":549.36,"end":550.32,"text":"¡Empiecen!","type":"dialogue"},{"start":840.32,"end":551.92,"text":"Se llama kendo","type":"dialogue"},{"start":840.32,"end":555,"text":"Es fácil de seguir. Puntúas por cada golpe certero","type":"dialogue"},{"start":559.4,"end":560.8,"text":"¡Eres increíble!","type":"dialogue"},{"start":561.64,"end":563,"text":"¡Guau!","type":"dialogue"},{"start":563.88,"end":566.36,"text":"-¡Guau!\\n-Es muy buena","type":"dialogue"},{"start":566.36,"end":567.48,"text":"¡Reanuden el combate!","type":"dialogue"},{"start":600.16,"end":601,"text":"¡Tenemos una ganadora!","type":"dialogue"},{"start":640.04,"end":641.08,"text":"Oye, no tapes","type":"dialogue"},{"start":641.08,"end":642.8,"text":"-Siéntate, siéntate.\\n-Oye","type":"dialogue"},{"start":645.72,"end":646.84,"text":"Esa de último año","type":"dialogue"},{"start":647.32,"end":648.44,"text":"Ella...","type":"dialogue"},{"start":651.4,"end":652.76,"text":"Se llama Tawan","type":"dialogue"},{"start":652.84,"end":656.04,"text":"Está en grado 12. Es una estudiante sobresaliente","type":"dialogue"},{"start":656.04,"end":657.48,"text":"La presidenta escolar","type":"dialogue"},{"start":657.56,"end":660.36,"text":"Y es la campeona de kendo de nuestra escuela","type":"dialogue"},{"start":660.92,"end":663.32,"text":"Es tres veces campeona","type":"dialogue"},{"start":664.12,"end":665.2,"text":"Guau","type":"dialogue"},{"start":665.8,"end":667.4,"text":"¿Buena en los estudios y en el deporte?","type":"dialogue"},{"start":668.48,"end":670.56,"text":"Es buena en todo","type":"dialogue"},{"start":672.04,"end":673.4,"text":"Y es hermosa","type":"dialogue"},{"start":673.48,"end":675.72,"text":"Genial. La palabra es \"genial","type":"dialogue"},{"start":677.12,"end":679.48,"text":"En fin, ¿a qué club te vas a unir?","type":"dialogue"},{"start":684,"end":685.4,"text":"(Únete al Club de Kendo)","type":"dialogue"},{"start":688.84,"end":691.12,"text":"¿Estás realmente segura?","type":"dialogue"},{"start":691.12,"end":692.16,"text":"Lo estoy","type":"dialogue"},{"start":692.16,"end":694,"text":"Quiero unirme al club de kendo","type":"dialogue"},{"start":697.36,"end":698.36,"text":"Pero...","type":"dialogue"},{"start":698.56,"end":701.36,"text":"Creo que el entrenamiento es muy intenso","type":"dialogue"},{"start":701.56,"end":703.44,"text":"No creo que puedas soportarlo","type":"dialogue"},{"start":705.36,"end":706.88,"text":"Estoy segura de que puedo","type":"dialogue"},{"start":707.68,"end":709.36,"text":"Estoy súper lista. Cuenten conmigo","type":"dialogue"},{"start":711.92,"end":714.92,"text":"Veamos cómo te va en la prueba","type":"dialogue"},{"start":715,"end":716.48,"text":"¿Están listas, chicas?","type":"dialogue"},{"start":717.92,"end":719,"text":"¡Sí!","type":"dialogue"},{"start":741.76,"end":745.04,"text":"Por lo que se ve, esa debilucha no lo logrará","type":"dialogue"},{"start":745.84,"end":748.28,"text":"Mírenla. Está a punto de desmayarse","type":"dialogue"},{"start":750.16,"end":751.96,"text":"Déjenla entrar si eso es lo que quiere","type":"dialogue"},{"start":753.28,"end":754.16,"text":"Cierto","type":"dialogue"},{"start":755.04,"end":756.84,"text":"¿Y quién la va a entrenar?","type":"dialogue"},{"start":760.48,"end":761.4,"text":"Yo lo haré","type":"dialogue"},{"start":763.52,"end":764.76,"text":"Tú lo dijiste","type":"dialogue"},{"start":765.32,"end":766.8,"text":"Tú la entrenas","type":"dialogue"},{"start":767.08,"end":768.08,"text":"¿Trato?","type":"dialogue"},{"start":768.88,"end":769.88,"text":"Trato","type":"dialogue"},{"start":772.36,"end":773.48,"text":"Muy bien","type":"dialogue"},{"start":773.76,"end":775.36,"text":"Niña, deja de correr","type":"dialogue"},{"start":775.44,"end":776.76,"text":"Estás dentro","type":"dialogue"},{"start":776.76,"end":777.92,"text":"Buen esfuerzo","type":"dialogue"},{"start":778.36,"end":780,"text":"Nos vemos mañana en el club","type":"dialogue"},{"start":791.48,"end":793.12,"text":"Levántate y bebe algo de agua","type":"dialogue"},{"start":798.96,"end":800.4,"text":"Hola, Tawan","type":"dialogue"},{"start":804.6,"end":805.76,"text":"Me siento mareada","type":"dialogue"},{"start":752.28,"end":808.52,"text":"¿Estás bien?","type":"dialogue"},{"start":817.48,"end":818.92,"text":"Gracias, Tawan","type":"dialogue"},{"start":822.76,"end":824.28,"text":"¿Te acuerdas de mí?","type":"dialogue"},{"start":831.32,"end":832.76,"text":"Ahora ya sabes mi nombre","type":"dialogue"},{"start":833.04,"end":834.52,"text":"Este club es exigente","type":"dialogue"},{"start":835.96,"end":836.96,"text":"Sí","type":"dialogue"},{"start":838.2,"end":840.32,"text":"Me esforzaré al máximo","type":"dialogue"},{"start":841.08,"end":842.92,"text":"Gracias por aceptarme","type":"dialogue"},{"start":844.52,"end":845.52,"text":"Ve","type":"dialogue"},{"start":846.52,"end":847.56,"text":"Es hora de ir a casa","type":"dialogue"},{"start":849,"end":850.64,"text":"Nos vemos en el club mañana","type":"dialogue"},{"start":852,"end":853.08,"text":"Ayla","type":"dialogue"},{"start":856.2,"end":857.6,"text":"¡Adiós, Tawan!","type":"dialogue"},{"start":862.92,"end":865.08,"text":"Sabe mi nombre","type":"dialogue"},{"start":868.68,"end":870.32,"text":"Sabe mi nombre","type":"dialogue"},{"start":876.64,"end":877.64,"text":"¡Ah!","type":"dialogue"},{"start":896.64,"end":898.36,"text":"Antes de empezar,","type":"dialogue"},{"start":899,"end":901.4,"text":"les mostraré cómo entrenamos kendo","type":"dialogue"},{"start":903.8,"end":905.72,"text":"¡A pelear! ¡Empiecen!","type":"dialogue"},{"start":921.96,"end":923.96,"text":"¡Cabeza! ¡Empiecen!","type":"dialogue"},{"start":931.68,"end":933.28,"text":"¡Muñeca! ¡Empiecen!","type":"dialogue"},{"start":939.56,"end":941.44,"text":"¡Torso! ¡Empiecen!","type":"dialogue"},{"start":946.36,"end":947.84,"text":"¡Saludo!","type":"dialogue"},{"start":950.12,"end":953.24,"text":"Comenzarán por lo fundamental","type":"dialogue"},{"start":953.56,"end":954.72,"text":"¿Están listas?","type":"dialogue"},{"start":954.8,"end":955.88,"text":"-¡Sí!\\n-¡Sí!","type":"dialogue"},{"start":960.64,"end":961.8,"text":"El kendo,","type":"dialogue"},{"start":962.16,"end":963.72,"text":"el camino de la espada,","type":"dialogue"},{"start":964.48,"end":967.32,"text":"se basa en la esgrima samurái","type":"dialogue"},{"start":967.84,"end":970.28,"text":"Para entrenar los movimientos de kendo","type":"dialogue"},{"start":970.96,"end":974.52,"text":"que son veloces, fuertes y decisivos,","type":"dialogue"},{"start":974.84,"end":977.92,"text":"se requiere una concentración profunda","type":"dialogue"},{"start":992.12,"end":993.12,"text":"Vamos","type":"dialogue"},{"start":999.84,"end":1002.04,"text":"¡Vamos! ¡Corran!","type":"dialogue"},{"start":1028,"end":1028.92,"text":"¡Hala!","type":"dialogue"},{"start":1029,"end":1030.28,"text":"Danos un poco","type":"dialogue"},{"start":1031.4,"end":1032.72,"text":"Sí, toma un poco","type":"dialogue"},{"start":1033.52,"end":1035.24,"text":"-Dame algo.\\n-Este también","type":"dialogue"},{"start":1100.16,"end":1102.44,"text":"Tawan recibió mi regalo","type":"dialogue"},{"start":1105.8,"end":1107.2,"text":"Recibió mi regalo","type":"dialogue"},{"start":1128.16,"end":1129.76,"text":"Realmente está diluviando","type":"dialogue"},{"start":1132.4,"end":1133.4,"text":"Tawan","type":"dialogue"},{"start":1134.36,"end":1135.52,"text":"¿Aún no te has ido?","type":"dialogue"},{"start":1136.68,"end":1139.68,"text":"Bueno, olvidé traer mi paraguas","type":"dialogue"},{"start":1145,"end":1146.84,"text":"Yo también olvidé el mío","type":"dialogue"},{"start":1148,"end":1149,"text":"Así que...","type":"dialogue"},{"start":1149.8,"end":1151.68,"text":"¿por qué no buscamos \"detiene-lluvias\"?","type":"dialogue"},{"start":1153.84,"end":1154.96,"text":"¿Detiene-lluvias?","type":"dialogue"},{"start":1156.04,"end":1157.08,"text":"¿Qué es eso?","type":"dialogue"},{"start":1157.88,"end":1159.24,"text":"Hagamos amuletos para ahuyentar la lluvia","type":"dialogue"},{"start":1160.04,"end":1161.28,"text":"¿Amuletos para la lluvia?","type":"dialogue"},{"start":1180.48,"end":1181.52,"text":"Toma","type":"dialogue"},{"start":1194.56,"end":1197.8,"text":"Oh, ahí está el sol. Muy genial","type":"dialogue"},{"start":1199,"end":1201.76,"text":"Sol es otro significado para \"Tawan","type":"dialogue"},{"start":1210.32,"end":1212.04,"text":"¿Estás dibujando la luna?","type":"dialogue"},{"start":1213.36,"end":1214.48,"text":"Así es","type":"dialogue"},{"start":1215.48,"end":1217.2,"text":"¿Por qué la luna?","type":"dialogue"},{"start":1218.92,"end":1220.92,"text":"Ayla es otra palabra para decir luna","type":"dialogue"},{"start":1222.84,"end":1223.84,"text":"Ya veo","type":"dialogue"},{"start":1231.16,"end":1233.12,"text":"El sol y la luna","type":"dialogue"},{"start":1233.84,"end":1235.24,"text":"Tawan y Ayla","type":"dialogue"},{"start":1235.24,"end":1239.2,"text":"♪ Ni una sola vez notaste ♪","type":"dialogue"},{"start":1239.2,"end":1242.72,"text":"♪ Lo que sentía mi corazón ♪","type":"dialogue"},{"start":1242.72,"end":1246.24,"text":"♪ Cuando te miro, mis ojos lo dicen todo ♪","type":"dialogue"},{"start":1246.32,"end":1251.16,"text":"♪ Esperando solo que me prestes atención ♪","type":"dialogue"},{"start":1251.24,"end":1257.56,"text":"♪ Mi corazón grita cada día pero su voz nunca te alcanza ♪","type":"dialogue"},{"start":1257.56,"end":1261.6,"text":"♪ Quiero que sepas cuánto tiempo he guardado esto ♪","type":"dialogue"},{"start":1261.6,"end":1266.24,"text":"♪ ¿Tienes alguna idea? ♪","type":"dialogue"},{"start":1266.24,"end":1268.92,"text":"♪ Mientras cada minuto pasa ♪","type":"dialogue"},{"start":1268.92,"end":1274.64,"text":"♪ ¿Cuánto desea mi corazón decirte que te amo? ♪","type":"dialogue"},{"start":1275.68,"end":1279.56,"text":"♪ Solo sé que mi corazón es terco ♪","type":"dialogue"},{"start":1279.56,"end":1281.92,"text":"♪ Incluso cuando me ignoras ♪","type":"dialogue"},{"start":1281.92,"end":1283.6,"text":"- ♪ Hay dolor, pero también amor ♪\\n- Aquí vamos","type":"dialogue"},{"start":1283.6,"end":1287.76,"text":"♪ Que nunca ha disminuido ♪","type":"dialogue"},{"start":1287.76,"end":1291.76,"text":"♪ Cuanto más cerca estamos, más lejos se siente ♪","type":"dialogue"},{"start":1291.76,"end":1295.2,"text":"♪ Ni una sola vez ♪","type":"dialogue"},{"start":1295.2,"end":1299.12,"text":"♪ Notaste lo que ♪","type":"dialogue"},{"start":1299.12,"end":1302.36,"text":"♪ Mi corazón sentía ♪","type":"dialogue"},{"start":1302.8,"end":1304.64,"text":"♪ Cuando te miro ♪","type":"dialogue"},{"start":1304.64,"end":1307,"text":"- ♪ Mis ojos lo dicen todo ♪\\n- ¡Mira! La lluvia paró","type":"dialogue"},{"start":1307,"end":1311.68,"text":"- ♪ Esperando solo que me prestes atención ♪\\n- Realmente funciona.","type":"dialogue"},{"start":1311.68,"end":1317,"text":"♪ Mi corazón grita cada día pero su voz nunca te alcanza ♪","type":"dialogue"},{"start":1317,"end":1319.64,"text":"- ♪ Quiero que sepas ♪\\n- Gracias, amuletos de lluvia","type":"dialogue"},{"start":1319.64,"end":1322.08,"text":"♪ Cuánto tiempo he guardado esto ♪","type":"dialogue"},{"start":1322.08,"end":1326.68,"text":"♪ ¿Tienes alguna idea? ♪","type":"dialogue"},{"start":1326.68,"end":1329.36,"text":"♪ Mientras cada minuto pasa ♪","type":"dialogue"},{"start":1329.36,"end":1334.88,"text":"♪ ¿Cuánto desea mi corazón decirte que te amo? ♪","type":"dialogue"},{"start":1338.52,"end":1339.56,"text":"Tawan","type":"dialogue"},{"start":1343.12,"end":1345.12,"text":"Estoy bien. Gracias","type":"dialogue"},{"start":1346.68,"end":1348.24,"text":"-Yo me llevo eso.\\n-Tawan","type":"dialogue"},{"start":1367.04,"end":1368.04,"text":"Oye","type":"dialogue"}]
